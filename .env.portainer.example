# Image tag published by the GHCR workflow. Prefer sha-<40-character-commit>.
APP_IMAGE_TAG=latest

# Example host paths; replace them with existing host directories writable by
# the configured PUID:PGID. These values are not hardcoded in docker-compose.yml.
APP_DATA_PATH=/srv/wedding-gallery/app
MEDIA_PATH=/srv/wedding-gallery/media
TUS_UPLOAD_PATH=/srv/wedding-gallery/uploads
# Optional container identity; both values default to 1000 when omitted.
PUID=1000
PGID=1000

# Generate independent random values; do not commit the real values.
ADMIN_PASSWORD=replace-with-a-strong-password
TUS_HOOK_SECRET=replace-with-at-least-32-random-characters
CLOUDFLARE_TUNNEL_TOKEN=replace-with-the-remotely-managed-tunnel-token

TZ=UTC
UMASK=022
MAX_UPLOAD_BYTES=5368709120
PUBLIC_RATE_LIMIT_PER_MINUTE=12000
PUBLIC_RATE_LIMIT_BURST=3000
UPLOAD_CONCURRENCY_PER_IP=50
UPLOAD_BANDWIDTH_PER_IP_BYTES_PER_SEC=1073741824
EDGE_SUBNET=172.30.0.0/24
