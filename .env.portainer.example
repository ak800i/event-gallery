# Image tag published by the GHCR workflow. Prefer sha-<40-character-commit>.
APP_IMAGE_TAG=latest

# Existing NAS directories, writable by PUID:PGID.
APP_DATA_PATH=/volume1/docker/wedding-gallery/app
MEDIA_PATH=/volume1/photos/wedding-gallery
TUS_UPLOAD_PATH=/volume1/docker/wedding-gallery/uploads
PUID=1000
PGID=1000

# Generate independent random values; do not commit the real values.
ADMIN_PASSWORD=replace-with-a-strong-password
TUS_HOOK_SECRET=replace-with-at-least-32-random-characters
CLOUDFLARE_TUNNEL_TOKEN=replace-with-the-remotely-managed-tunnel-token

TZ=UTC
UMASK=022
MAX_UPLOAD_BYTES=314572800
EDGE_SUBNET=172.30.0.0/24
